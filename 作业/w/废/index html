<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>三等分布局（Flex）</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    /* 父容器 */
    .container {
      display: flex; /* 开启Flex布局 */
      width: 100%;
      height: 300px; /* 可自定义高度 */
      gap: 10px; /* 列之间的间距（可选） */
      padding: 10px;
    }
    /* 三等分列 */
    .col {
      flex: 1; /* 平分剩余空间，实现三等分 */
      background: #f5f5f5;
      border: 1px solid #ddd;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="col">列1</div>
    <div class="col">列2</div>
    <div class="col">列3</div>
  </div>
</body>
</html>